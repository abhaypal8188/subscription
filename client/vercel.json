{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "@vercel/static-build": {
        "postinstall": "npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "http://localhost:5000/api/$1"
    }
  ],
  "env": {
    "VITE_SERVER_URL": "https://your-server.vercel.app"
  }
}
