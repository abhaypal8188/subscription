{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {"key": "Access-Control-Allow-Origin", "value": "${CLIENT_URL || \"http://localhost:5173\"}"},
        {"key": "Access-Control-Allow-Credentials", "value": "true"},
        {"key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, PATCH, OPTIONS"},
        {"key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization"}
      ]
    }
  ],
  "functions": {
    "src/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
